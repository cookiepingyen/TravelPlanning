<Page x:Class="TravelPlanning.Views.Pages.PlaceSearchPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:TravelPlanning.Views.Pages"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PlaceSearchPage">

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- 側邊欄 -->
            <ColumnDefinition Width="Auto"/>
            <!-- 收合按鈕 -->
            <ColumnDefinition Width="Auto"/>
            <!-- 地圖區域 -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 側邊欄 Panel -->
        <Border x:Name="Sidebar"
                Grid.Column="0"
                Width="280"
                Background="White"
                BorderBrush="#DDDDDD"
                BorderThickness="0,0,1,0"
                ClipToBounds="True">
            <StackPanel Margin="16">
                <TextBlock Text="地點搜尋" FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>
                <TextBox Padding="8,6" FontSize="13" Margin="0,0,0,8"/>
                <ListBox BorderThickness="0" FontSize="13">
                    <ListBoxItem Padding="4,8">地點結果 1</ListBoxItem>
                    <ListBoxItem Padding="4,8">地點結果 2</ListBoxItem>
                    <ListBoxItem Padding="4,8">地點結果 3</ListBoxItem>
                </ListBox>
            </StackPanel>
        </Border>

        <!-- 展開/收合 按鈕 -->
        <ToggleButton x:Name="ToggleBtn"
                      Grid.Column="1"
                      Width="20" Height="60"
                      VerticalAlignment="Center"
                      Background="White"
                      BorderBrush="#DDDDDD"
                      BorderThickness="0,1,1,1"
                      Content="◀"
                      FontSize="10">
            <ToggleButton.Triggers>
                <!-- 收合 -->
                <EventTrigger RoutedEvent="ToggleButton.Checked">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="Sidebar"
                                             Storyboard.TargetProperty="Width"
                                             To="0" Duration="0:0:0.25"/>
                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ToggleBtn"
                                                           Storyboard.TargetProperty="Content">
                                <DiscreteObjectKeyFrame KeyTime="0:0:0.25" Value="▶"/>
                            </ObjectAnimationUsingKeyFrames>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <!-- 展開 -->
                <EventTrigger RoutedEvent="ToggleButton.Unchecked">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="Sidebar"
                                             Storyboard.TargetProperty="Width"
                                             To="280" Duration="0:0:0.25"/>
                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ToggleBtn"
                                                           Storyboard.TargetProperty="Content">
                                <DiscreteObjectKeyFrame KeyTime="0" Value="◀"/>
                            </ObjectAnimationUsingKeyFrames>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </ToggleButton.Triggers>
        </ToggleButton>

        <!-- 地圖區域（code-behind 的 mapControl 加在這裡） -->
        <Grid x:Name="container"
              Grid.Column="2"/>
    </Grid>
</Page>
