<Page
    x:Class="TravelPlanning.Views.Pages.PlaceSearchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:TravelPlanning.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:TravelPlanning.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="PlaceSearchPage"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <Page.Resources>
        <!--  深色背景色  -->
        <SolidColorBrush x:Key="DarkBg" Color="#1E1E1E" />
        <SolidColorBrush x:Key="DarkNavBg" Color="#2A2A2A" />
        <SolidColorBrush x:Key="DarkSidebarBg" Color="#242424" />
        <SolidColorBrush x:Key="DarkBorder" Color="#3A3A3A" />
        <SolidColorBrush x:Key="ActiveBlue" Color="#4DA3FF" />
        <SolidColorBrush x:Key="ActiveBlueBg" Color="#1A3A5C" />
        <SolidColorBrush x:Key="TextPrimary" Color="#E8EAED" />
        <SolidColorBrush x:Key="TextSecondary" Color="#9AA0A6" />
        <SolidColorBrush x:Key="InputBg" Color="#303030" />
        <SolidColorBrush x:Key="ToggleBg" Color="#2A2A2A" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:RatingToStarsConverter x:Key="RatingToStarsConverter" />
    </Page.Resources>

    <Grid Background="{StaticResource DarkBg}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="72" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  左側 NavBar  -->
        <Border
            Grid.Column="0"
            Background="{StaticResource DarkNavBg}"
            BorderBrush="{StaticResource DarkBorder}"
            BorderThickness="0,0,1,0">
            <StackPanel Margin="0,12,0,0" VerticalAlignment="Top">

                <!--  已儲存（選中狀態）  -->
                <Button
                    Width="60"
                    Height="60"
                    Margin="0,4"
                    HorizontalAlignment="Center"
                    Background="{StaticResource ActiveBlueBg}"
                    BorderThickness="0"
                    Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border
                                Padding="4"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <StackPanel HorizontalAlignment="Center">
                        <ui:SymbolIcon
                            Filled="True"
                            Foreground="{StaticResource ActiveBlue}"
                            Symbol="Bookmark24" />
                        <TextBlock
                            Margin="0,3,0,0"
                            HorizontalAlignment="Center"
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource ActiveBlue}"
                            Text="已儲存" />
                    </StackPanel>
                </Button>

                <!--  最近  -->
                <Button
                    Width="60"
                    Height="60"
                    Margin="0,4"
                    HorizontalAlignment="Center"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border
                                x:Name="HoverBorder"
                                Padding="4"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="HoverBorder" Property="Background" Value="#333333" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <StackPanel HorizontalAlignment="Center">
                        <ui:SymbolIcon Foreground="{StaticResource TextSecondary}" Symbol="History24" />
                        <TextBlock
                            Margin="0,3,0,0"
                            HorizontalAlignment="Center"
                            FontSize="11"
                            Foreground="{StaticResource TextSecondary}"
                            Text="最近" />
                    </StackPanel>
                </Button>

            </StackPanel>
        </Border>

        <!--  側邊欄 Panel  -->
        <Border
            x:Name="Sidebar"
            Grid.Column="1"
            Width="350"
            Background="{StaticResource DarkSidebarBg}"
            BorderBrush="{StaticResource DarkBorder}"
            BorderThickness="0,0,1,0"
            ClipToBounds="True">
            <StackPanel Margin="16">
                <TextBlock
                    Margin="0,0,0,12"
                    FontSize="16"
                    FontWeight="Bold"
                    Foreground="{StaticResource TextPrimary}"
                    Text="地點搜尋" />

                <!--  搜尋框  -->
                <Border
                    Margin="0,0,0,12"
                    Background="{StaticResource InputBg}"
                    BorderBrush="{StaticResource DarkBorder}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ui:SymbolIcon
                            Grid.Column="0"
                            Margin="10,0,6,0"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource TextSecondary}"
                            Symbol="Search24" />

                        <StackPanel
                            x:Name="autoCompletePanel"
                            Grid.Column="1"
                            Orientation="Vertical" />

                    </Grid>
                </Border>

                <!--  ===== PlaceCard 詳細資訊面板 =====  -->
                <Border
                    x:Name="PlaceCardPanel"
                    Margin="0,8,0,0"
                    Padding="16"
                    Background="#2C2C2C"
                    BorderBrush="{StaticResource DarkBorder}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Visibility="{Binding IsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel>

                        <!--  地點圖片  -->
                        <Border
                            Margin="-16,-16,-16,12"
                            ClipToBounds="True"
                            CornerRadius="12,12,0,0">
                            <Image
                                Height="200"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Source="{Binding Photo}"
                                Stretch="UniformToFill" />
                        </Border>

                        <!--  地點名稱  -->
                        <TextBlock
                            Margin="0,0,0,6"
                            FontSize="16"
                            FontWeight="Bold"
                            Foreground="{StaticResource TextPrimary}"
                            Text="{Binding PlaceName}"
                            TextWrapping="Wrap" />

                        <!--  評分 + 評論數  -->
                        <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="#FBBC04"
                                Text="{Binding Rating}" />
                            <TextBlock
                                Margin="2,0,4,0"
                                VerticalAlignment="Center"
                                FontSize="13"
                                Foreground="#FBBC04"
                                Text="{Binding Rating, Converter={StaticResource RatingToStarsConverter}}" />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="12"
                                Foreground="{StaticResource TextSecondary}"
                                Text="{Binding UserRatingsTotal}" />
                        </StackPanel>

                        <Separator Margin="0,0,0,8" Background="{StaticResource DarkBorder}" />

                        <!--  Tab 列：菜單 / 評論  -->
                        <StackPanel Margin="0,0,0,4" Orientation="Horizontal">
                            <Button
                                Padding="16,6"
                                Background="Transparent"
                                BorderBrush="{StaticResource ActiveBlue}"
                                BorderThickness="0,0,0,2"
                                Content="總覽"
                                Cursor="Hand"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource ActiveBlue}" />
                            <Button
                                Padding="16,6"
                                Background="Transparent"
                                BorderThickness="0"
                                Content="評論"
                                Cursor="Hand"
                                FontSize="13"
                                Foreground="{StaticResource TextSecondary}" />
                        </StackPanel>

                        <Separator Margin="0,0,0,12" Background="{StaticResource DarkBorder}" />

                        <!--  動作按鈕列：規劃路線 / 儲存地點  -->
                        <StackPanel
                            Margin="0,0,0,12"
                            HorizontalAlignment="Left"
                            Orientation="Horizontal">

                            <!--  規劃路線  -->
                            <StackPanel
                                Width="60"
                                Margin="0,0,16,0"
                                HorizontalAlignment="Center"
                                Cursor="Hand">
                                <Border
                                    Width="44"
                                    Height="44"
                                    HorizontalAlignment="Center"
                                    Background="{StaticResource ActiveBlueBg}"
                                    CornerRadius="22">
                                    <ui:SymbolIcon
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Foreground="{StaticResource ActiveBlue}"
                                        Symbol="Navigation24" />
                                </Border>
                                <TextBlock
                                    Margin="0,4,0,0"
                                    HorizontalAlignment="Center"
                                    FontSize="11"
                                    Foreground="{StaticResource TextSecondary}"
                                    Text="規劃路線"
                                    TextAlignment="Center"
                                    TextWrapping="Wrap" />
                            </StackPanel>

                            <!--  儲存地點  -->
                            <StackPanel
                                Width="60"
                                HorizontalAlignment="Center"
                                Cursor="Hand">
                                <Border
                                    Width="44"
                                    Height="44"
                                    HorizontalAlignment="Center"
                                    Background="{StaticResource InputBg}"
                                    CornerRadius="22">
                                    <ui:SymbolIcon
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Foreground="{StaticResource TextPrimary}"
                                        Symbol="Bookmark24" />
                                </Border>
                                <TextBlock
                                    Margin="0,4,0,0"
                                    HorizontalAlignment="Center"
                                    FontSize="11"
                                    Foreground="{StaticResource TextSecondary}"
                                    Text="儲存地點"
                                    TextAlignment="Center"
                                    TextWrapping="Wrap" />
                            </StackPanel>

                        </StackPanel>

                        <Separator Margin="0,0,0,8" Background="{StaticResource DarkBorder}" />

                        <!--  營業狀態  -->
                        <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
                            <ui:SymbolIcon
                                Margin="0,0,8,0"
                                Foreground="#34A853"
                                Symbol="Clock24" />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="13"
                                Foreground="#34A853"
                                Text="{Binding BusinessStatus}" />
                        </StackPanel>

                        <!--  地址  -->
                        <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
                            <ui:SymbolIcon
                                Margin="0,0,8,0"
                                Foreground="{StaticResource TextSecondary}"
                                Symbol="Location24" />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="12"
                                Foreground="{StaticResource TextSecondary}"
                                Text="{Binding Address}"
                                TextWrapping="Wrap" />
                        </StackPanel>

                        <!--  電話  -->
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon
                                Margin="0,0,8,0"
                                Foreground="{StaticResource TextSecondary}"
                                Symbol="Call24" />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="12"
                                Foreground="{StaticResource TextSecondary}"
                                Text="{Binding Phone}" />
                        </StackPanel>

                    </StackPanel>
                </Border>
                <!--  ===== PlaceCard 結束 =====  -->

            </StackPanel>
        </Border>

        <!--  展開/收合 按鈕  -->
        <ToggleButton
            x:Name="ToggleBtn"
            Grid.Column="2"
            Width="20"
            Height="60"
            VerticalAlignment="Center"
            Background="{StaticResource ToggleBg}"
            BorderBrush="{StaticResource DarkBorder}"
            BorderThickness="0,1,1,1"
            Content="◀"
            FontSize="10"
            Foreground="{StaticResource TextSecondary}">
            <ToggleButton.Triggers>
                <EventTrigger RoutedEvent="ToggleButton.Checked">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetName="Sidebar"
                                Storyboard.TargetProperty="Width"
                                To="0"
                                Duration="0:0:0.25" />
                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ToggleBtn" Storyboard.TargetProperty="Content">
                                <DiscreteObjectKeyFrame KeyTime="0:0:0.25" Value="▶" />
                            </ObjectAnimationUsingKeyFrames>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="ToggleButton.Unchecked">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetName="Sidebar"
                                Storyboard.TargetProperty="Width"
                                To="300"
                                Duration="0:0:0.25" />
                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ToggleBtn" Storyboard.TargetProperty="Content">
                                <DiscreteObjectKeyFrame KeyTime="0" Value="◀" />
                            </ObjectAnimationUsingKeyFrames>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </ToggleButton.Triggers>
        </ToggleButton>

        <!--  地圖區域  -->
        <Grid
            x:Name="container"
            Grid.Column="3"
            Background="{StaticResource DarkBg}" />
    </Grid>
</Page>