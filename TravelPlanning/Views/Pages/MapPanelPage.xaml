<Page
    x:Class="TravelPlanning.Views.Pages.MapPanelPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:autoComplete="clr-namespace:TravelPlanning.Components.AutoCompleteComponent"
    xmlns:converters="clr-namespace:TravelPlanning.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:TravelPlanning.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="PlaceSearchPage"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <Page.Resources>
        <!--  深色背景色  -->
        <SolidColorBrush x:Key="DarkBg" Color="#1E1E1E" />
        <SolidColorBrush x:Key="DarkNavBg" Color="#2A2A2A" />
        <SolidColorBrush x:Key="DarkSidebarBg" Color="#242424" />
        <SolidColorBrush x:Key="DarkBorder" Color="#3A3A3A" />
        <SolidColorBrush x:Key="ActiveBlue" Color="#4DA3FF" />
        <SolidColorBrush x:Key="ActiveBlueBg" Color="#1A3A5C" />
        <SolidColorBrush x:Key="TextPrimary" Color="#E8EAED" />
        <SolidColorBrush x:Key="TextSecondary" Color="#9AA0A6" />
        <SolidColorBrush x:Key="InputBg" Color="#303030" />
        <SolidColorBrush x:Key="ToggleBg" Color="#2A2A2A" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:RatingToStarsConverter x:Key="RatingToStarsConverter" />
        <Style x:Key="NavButtonStyle" TargetType="RadioButton">
            <Setter Property="Width" Value="60" />
            <Setter Property="Height" Value="60" />
            <Setter Property="Margin" Value="0,4" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border
                            x:Name="Bg"
                            Padding="4"
                            Background="{TemplateBinding Background}"
                            CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource ActiveBlueBg}" />
                                <Setter Property="Foreground" Value="{StaticResource ActiveBlue}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsChecked" Value="False" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bg" Property="Background" Value="#333333" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TabRadioButtonStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0,0,0,2" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource ActiveBlue}" />
                                <Setter Property="BorderBrush" Value="{StaticResource ActiveBlue}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
                                <Setter Property="BorderBrush" Value="Transparent" />
                                <Setter Property="FontWeight" Value="Normal" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Background="{StaticResource DarkBg}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="72" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  左側 NavBar  -->
        <Border
            Grid.Column="0"
            Background="{StaticResource DarkNavBg}"
            BorderBrush="{StaticResource DarkBorder}"
            BorderThickness="0,0,1,0">
            <StackPanel Margin="0,12,0,0" VerticalAlignment="Top">

                <!--  已儲存  -->
                <RadioButton
                    GroupName="NavGroup"
                    IsChecked="True"
                    Command="{Binding PlaceSearchCommand}"
                    Style="{StaticResource NavButtonStyle}">
                    <StackPanel HorizontalAlignment="Center">
                        <ui:SymbolIcon Symbol="Bookmark24" />
                        <TextBlock
                            Margin="0,3,0,0"
                            HorizontalAlignment="Center"
                            FontSize="11"
                            Text="已儲存" />
                    </StackPanel>
                </RadioButton>

                <!--  路線  -->
                <RadioButton
                    GroupName="NavGroup"
                    Command="{Binding RoutePlanningPageCommand}"
                    Style="{StaticResource NavButtonStyle}">
                    <StackPanel HorizontalAlignment="Center">
                        <ui:SymbolIcon Symbol="Directions16" />
                        <TextBlock
                            Margin="0,3,0,0"
                            HorizontalAlignment="Center"
                            FontSize="11"
                            Text="路線" />
                    </StackPanel>
                </RadioButton>

            </StackPanel>
        </Border>

        <!--  側邊欄 Panel  -->
        <Border
            x:Name="Sidebar"
            Grid.Column="1"
            Width="350"
            Background="{StaticResource DarkSidebarBg}"
            BorderBrush="{StaticResource DarkBorder}"
            BorderThickness="0,0,1,0"
            ClipToBounds="True">
            <Frame x:Name="frame" />


        </Border>

        <!--  展開/收合 按鈕  -->
        <ToggleButton
            x:Name="ToggleBtn"
            Grid.Column="2"
            Width="20"
            Height="60"
            Margin="0,350,0,0"
            VerticalAlignment="Top"
            Background="{StaticResource ToggleBg}"
            BorderBrush="{StaticResource DarkBorder}"
            BorderThickness="0,1,1,1"
            Content="◀"
            FontSize="10"
            Foreground="{StaticResource TextSecondary}">
            <ToggleButton.Triggers>
                <EventTrigger RoutedEvent="ToggleButton.Checked">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetName="Sidebar"
                                Storyboard.TargetProperty="Width"
                                To="0"
                                Duration="0:0:0.25" />
                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ToggleBtn" Storyboard.TargetProperty="Content">
                                <DiscreteObjectKeyFrame KeyTime="0:0:0.25" Value="▶" />
                            </ObjectAnimationUsingKeyFrames>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="ToggleButton.Unchecked">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetName="Sidebar"
                                Storyboard.TargetProperty="Width"
                                To="300"
                                Duration="0:0:0.25" />
                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ToggleBtn" Storyboard.TargetProperty="Content">
                                <DiscreteObjectKeyFrame KeyTime="0" Value="◀" />
                            </ObjectAnimationUsingKeyFrames>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </ToggleButton.Triggers>
        </ToggleButton>

        <!--  地圖區域  -->
        <Grid
            x:Name="container"
            Grid.Column="3"
            Background="{StaticResource DarkBg}" />
    </Grid>
</Page>