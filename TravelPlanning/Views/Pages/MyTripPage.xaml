<Page
    x:Class="TravelPlanning.Views.Pages.MyTripPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:TravelPlanning.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MyTripPage"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <Page.Resources>

        <!--  建立新行程按鈕（藍色）  -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#1A73E8" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="20,12" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1558B0" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--  "..." 圓形小按鈕  -->
        <Style x:Key="CircleIconButton" TargetType="Button">
            <Setter Property="Background" Value="#2A2A2A" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Background="{TemplateBinding Background}"
                            CornerRadius="16"
                            Opacity="0.85">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </Trigger>
            </Style.Triggers>
        </Style>

    </Page.Resources>

    <Grid Background="#2A2A2A">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  標題  -->
        <TextBlock
            Grid.Row="0"
            Margin="20"
            FontSize="28"
            FontWeight="Bold"
            Foreground="White"
            Text="我的行程" />

        <!--  建立新行程按鈕  -->
        <StackPanel
            Grid.Row="1"
            Margin="0,0,0,24"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                Margin="0,0,20,0"
                Command="{Binding CreateTripCommand}"
                Style="{StaticResource PrimaryButton}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,8,0"
                        FontFamily="Segoe MDL2 Assets"
                        FontWeight="Bold"
                        Text="&#xE710;" />
                    <TextBlock Text="建立新行程" />
                </StackPanel>
            </Button>
        </StackPanel>

        <!--  行程卡片列表  -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Trips}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Width="280"
                            Margin="0,0,24,24"
                            Background="#3A3A3A"
                            BorderBrush="#444444"
                            BorderThickness="1"
                            ClipToBounds="True"
                            CornerRadius="10">
                            <StackPanel>

                                <!--  封面圖 + 右上角 頭像 / 選單  -->
                                <Grid>
                                    <Image
                                        Height="180"
                                        Source="{Binding CoverImg}"
                                        Stretch="UniformToFill" />

                                    <StackPanel
                                        Margin="0,12,12,0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Orientation="Horizontal">

                                        <!--  擁有者頭像（圓形橘色，顯示名字首字）  -->
                                        <Border
                                            Width="32"
                                            Height="32"
                                            Margin="0,0,8,0"
                                            Background="#F0A030"
                                            CornerRadius="16">
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FontSize="12"
                                                FontWeight="Bold"
                                                Foreground="White"
                                                Text="{Binding OwnerName}" />
                                        </Border>

                                        <!--  "..." 選單按鈕  -->
                                        <Button
                                            Command="{Binding DataContext.TripMenuCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}"
                                            Content="&#x2022;&#x2022;&#x2022;"
                                            Style="{StaticResource CircleIconButton}" />
                                    </StackPanel>
                                </Grid>

                                <!--  行程名稱 / 日期  -->
                                <StackPanel Margin="16,12,16,16">
                                    <TextBlock
                                        Margin="0,0,0,6"
                                        FontSize="16"
                                        FontWeight="Bold"
                                        Foreground="White"
                                        Text="{Binding Name}" />
                                    <TextBlock FontSize="13" Foreground="#9A9AA0">
                                        <Run Text="{Binding StartDate, StringFormat='yyyy/MM/dd'}" />
                                        <Run Text=" - " />
                                        <Run Text="{Binding EndDate, StringFormat='yyyy/MM/dd'}" />
                                    </TextBlock>
                                </StackPanel>

                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </Grid>
</Page>