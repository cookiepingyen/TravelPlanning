<Page
    x:Class="TravelPlanning.Views.Pages.MyTripPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:TravelPlanning.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MyTripPage"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <Page.Resources>

        <!--  建立新行程按鈕（藍色）  -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#1A73E8" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="20,12" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1865D3" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1558B0" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--  "..." 圓形小按鈕：底色加深 + 邊框，確保在亮色封面圖上仍清晰可辨；改為 ToggleButton 以便掛 Popup  -->
        <Style x:Key="CircleIconButton" TargetType="ToggleButton">
            <Setter Property="Background" Value="#1A1A1A" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border
                            x:Name="IconBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8"
                            Opacity="0.78">
                            <Border.Effect>
                                <DropShadowEffect
                                    BlurRadius="6"
                                    Direction="270"
                                    Opacity="0.35"
                                    ShadowDepth="1"
                                    Color="Black" />
                            </Border.Effect>
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="16"
                                FontWeight="Bold"
                                Foreground="White"
                                Text="&#x22EF;" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="IconBorder" Property="Background" Value="#000000" />
                            </Trigger>
                            <!--  選單開啟時維持高亮，避免點擊後按鈕視覺上又「恢復原狀」造成混淆  -->
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="IconBorder" Property="Background" Value="#1A73E8" />
                                <Setter TargetName="IconBorder" Property="Opacity" Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  選單彈出視窗內的選項按鈕（紅色文字，代表危險操作）  -->
        <Style x:Key="DangerMenuItemButton" TargetType="Button">
            <Setter Property="Width" Value="120" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{x:Null}" />
            <Setter Property="Foreground" Value="#FF6B6B" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="ItemBorder"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#3A2222" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  行程卡片：加入 Hover 微互動（陰影 + 邊框亮起）  -->
        <Style x:Key="TripCard" TargetType="Border">
            <Setter Property="Width" Value="280" />
            <Setter Property="Background" Value="#3A3A3A" />
            <Setter Property="BorderBrush" Value="#444444" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="ClipToBounds" Value="True" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#1A73E8" />
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect
                                BlurRadius="16"
                                Direction="270"
                                Opacity="0.4"
                                ShadowDepth="4"
                                Color="#1A73E8" />
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Page.Resources>

    <Grid Background="#2A2A2A">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  標題  -->
        <TextBlock
            Grid.Row="0"
            Margin="20"
            FontSize="28"
            FontWeight="Bold"
            Foreground="White"
            Text="我的行程" />

        <!--  建立新行程按鈕  -->
        <StackPanel
            Grid.Row="1"
            Margin="0,0,0,24"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                Margin="0,0,20,0"
                Command="{Binding CreateTripPageCommand}"
                Style="{StaticResource PrimaryButton}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,8,0"
                        FontFamily="Segoe MDL2 Assets"
                        FontWeight="Bold"
                        Text="&#xE710;" />
                    <TextBlock Text="建立新行程" />
                </StackPanel>
            </Button>
        </StackPanel>

        <!--  行程卡片列表  -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl Margin="20,0,0,20" ItemsSource="{Binding Trips}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,24,24" Style="{StaticResource TripCard}">
                            <StackPanel>

                                <!--  封面圖 + 右上角 標記 / 選單  -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition />
                                    </Grid.ColumnDefinitions>

                                    <!--  深色底，避免圖片載入前出現刺眼白閃  -->
                                    <Border Height="180" Background="#1A1A1A">
                                        <Image Source="{Binding Cover}" Stretch="UniformToFill" />
                                    </Border>

                                    <!--  底部漸層遮罩，讓右上角圖示在任何封面圖上都看得清楚  -->
                                    <Border Height="60" VerticalAlignment="Top">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Offset="0" Color="#80000000" />
                                                <GradientStop Offset="1" Color="#00000000" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>

                                    <StackPanel
                                        Margin="0,12,12,0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Orientation="Horizontal">

                                        <!--  行程標記徽章：圓角矩形 + 地點圖示，不依賴文字長度，不再有溢出問題  -->
                                        <Border
                                            Width="32"
                                            Height="32"
                                            Margin="0,0,8,0"
                                            Background="#F0A030"
                                            CornerRadius="8">
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FontFamily="Segoe MDL2 Assets"
                                                FontSize="15"
                                                Foreground="White"
                                                Text="&#xE707;" />
                                        </Border>

                                        <!--  "..." 選單按鈕 + 下拉選單（刪除行程）  -->
                                        <Grid>
                                            <ToggleButton
                                                x:Name="MoreToggleButton"
                                                Style="{StaticResource CircleIconButton}"
                                                ToolTip="更多選項" />

                                            <Popup
                                                AllowsTransparency="True"
                                                IsOpen="{Binding IsChecked, ElementName=MoreToggleButton, Mode=TwoWay}"
                                                Placement="Bottom"
                                                PlacementTarget="{Binding ElementName=MoreToggleButton}"
                                                StaysOpen="False">
                                                <Border
                                                    Margin="0,4,0,0"
                                                    Background="#2D2D2D"
                                                    BorderBrush="#444444"
                                                    BorderThickness="1"
                                                    CornerRadius="8">
                                                    <Border.Effect>
                                                        <DropShadowEffect
                                                            BlurRadius="12"
                                                            Direction="270"
                                                            Opacity="0.35"
                                                            ShadowDepth="2"
                                                            Color="Black" />
                                                    </Border.Effect>
                                                    <StackPanel MinWidth="120">
                                                        <Button
                                                            Command="{Binding DataContext.DeleteTripCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                            CommandParameter="{Binding}"
                                                            Content="刪除行程"
                                                            Style="{StaticResource DangerMenuItemButton}" />
                                                    </StackPanel>
                                                </Border>
                                            </Popup>
                                        </Grid>
                                    </StackPanel>
                                </Grid>

                                <!--  行程名稱 / 日期 / 天數  -->
                                <StackPanel Margin="16,12,16,16">
                                    <TextBlock
                                        Margin="0,0,0,6"
                                        FontSize="16"
                                        FontWeight="Bold"
                                        Foreground="White"
                                        Text="{Binding Name}"
                                        TextTrimming="CharacterEllipsis" />
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontSize="13" Foreground="#9A9AA0">
                                            <Run Text="{Binding Started_time, StringFormat='yyyy/MM/dd'}" />
                                            <Run Text=" - " />
                                            <Run Text="{Binding End_time, StringFormat='yyyy/MM/dd'}" />
                                        </TextBlock>
                                        <TextBlock
                                            Margin="8,0,0,0"
                                            FontSize="13"
                                            Foreground="#6A6A70"
                                            Text="{Binding Days, StringFormat='・{0} 天'}" />
                                    </StackPanel>
                                </StackPanel>

                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </Grid>
</Page>
