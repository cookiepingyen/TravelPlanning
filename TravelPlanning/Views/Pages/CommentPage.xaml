<Page
    x:Class="TravelPlanning.Views.Pages.CommentPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:component="clr-namespace:TravelPlanning.Components.CommentComponent"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:TravelPlanning.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Comment"
    d:DesignHeight="450"
    d:DesignWidth="800"
    Cursor=""
    mc:Ignorable="d">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer
            Grid.Row="0"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding DisplayedComments}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <component:Comment />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Button
            Grid.Row="1"
            Margin="0,4,0,8"
            Padding="12,6"
            HorizontalAlignment="Center"
            Background="#3A3A3A"
            BorderThickness="0"
            Command="{Binding ShowMoreCommand}"
            Foreground="#9AA0A6"
            Visibility="{Binding HasMoreComments, Converter={StaticResource BooleanToVisibilityConverter}}">
            顯示更多
        </Button>
    </Grid>
</Page>
