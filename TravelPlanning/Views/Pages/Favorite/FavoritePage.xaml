<Page
    x:Class="TravelPlanning.Views.Pages.Favorite.FavoritePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:TravelPlanning.Views.Pages.Favorite"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="FavoritePage"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <ComboBox
            Grid.Column="0"
            Height="38"
            MinWidth="100"
            Margin="8,0,8,0"
            ItemsSource="{Binding Icons}"
            ScrollViewer.CanContentScroll="True"
            SelectedItem="{Binding SelectedIcon}"
            VirtualizingStackPanel.IsVirtualizing="True"
            VirtualizingStackPanel.VirtualizationMode="Recycling">
            <ComboBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel />
                </ItemsPanelTemplate>
            </ComboBox.ItemsPanel>
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            Symbol="{Binding}" />
                        <TextBlock VerticalAlignment="Center" Text="{Binding}" />
                    </StackPanel>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>
        <TextBox
            Grid.Column="1"
            Height="38"
            Margin="0,0,8,0"
            Text="{Binding FavoriteName}" />
        <Button
            Grid.Column="2"
            Height="38"
            Margin="0,0,8,0"
            Padding="14,0"
            Command="{Binding CreateFavoriteCommand}"
            Content="新增清單" />

        <StackPanel
            Grid.Row="1"
            Grid.Column="0"
            Grid.ColumnSpan="3">
            <ItemsControl ItemsSource="{Binding FavoriteListItems}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Margin="8"
                            Padding="12"
                            Background="#1E1E1E"
                            CornerRadius="12">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="40" />
                                </Grid.ColumnDefinitions>

                                <!--  左側 Icon  -->
                                <Border
                                    Width="32"
                                    Height="32"
                                    VerticalAlignment="Center"
                                    Background="#2D2D2D"
                                    CornerRadius="16">

                                    <ui:SymbolIcon
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Foreground="#8AB4F8"
                                        Symbol="{Binding Icon}" />
                                </Border>

                                <!--  中間文字  -->
                                <!--  中間文字  -->
                                <Grid
                                    Grid.Column="1"
                                    Margin="12,0,0,0"
                                    VerticalAlignment="Center">

                                    <!--  一般顯示模式  -->
                                    <StackPanel>
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <TextBlock
                                            FontSize="15"
                                            FontWeight="SemiBold"
                                            Foreground="White"
                                            Text="{Binding Name}" />
                                        <TextBlock
                                            Margin="0,4,0,0"
                                            FontSize="12"
                                            Foreground="#A0A0A0"
                                            Text="{Binding PlaceCount, StringFormat=私人 · {0} 個地點}" />
                                    </StackPanel>

                                    <!--  編輯模式  -->
                                    <StackPanel Orientation="Horizontal">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <TextBox
                                            Width="140"
                                            VerticalAlignment="Center"
                                            Text="{Binding EditingName, UpdateSourceTrigger=PropertyChanged}" />
                                        <Button
                                            Margin="6,0,0,0"
                                            Background="Transparent"
                                            BorderBrush="{x:Null}"
                                            Command="{Binding DataContext.ConfirmEditCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}"
                                            Cursor="Hand">
                                            <ui:SymbolIcon Foreground="#4CAF50" Symbol="Checkmark24" />
                                        </Button>
                                        <Button
                                            Margin="4,0,0,0"
                                            Background="Transparent"
                                            BorderBrush="{x:Null}"
                                            Command="{Binding DataContext.CancelEditCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}"
                                            Cursor="Hand">
                                            <ui:SymbolIcon Foreground="#FF6B6B" Symbol="Dismiss24" />
                                        </Button>
                                    </StackPanel>
                                </Grid>

                                <!--  右側更多按鈕  -->
                                <Grid Grid.Column="2">
                                    <ToggleButton
                                        x:Name="MoreToggleButton"
                                        Width="32"
                                        Height="32"
                                        Background="Transparent"
                                        BorderBrush="{x:Null}"
                                        Cursor="Hand">
                                        <ui:SymbolIcon Foreground="#B0B0B0" Symbol="MoreVertical24" />
                                    </ToggleButton>

                                    <Popup
                                        AllowsTransparency="True"
                                        IsOpen="{Binding IsChecked, ElementName=MoreToggleButton, Mode=TwoWay}"
                                        Placement="Bottom"
                                        PlacementTarget="{Binding ElementName=MoreToggleButton}"
                                        StaysOpen="False">
                                        <Border
                                            Background="#2D2D2D"
                                            BorderBrush="#444444"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                            <StackPanel MinWidth="120">
                                                <Button
                                                    Width="120"
                                                    Padding="12,8"
                                                    HorizontalContentAlignment="Left"
                                                    Background="Transparent"
                                                    BorderBrush="{x:Null}"
                                                    Command="{Binding DataContext.EditFavoriteCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                    CommandParameter="{Binding}"
                                                    Cursor="Hand"
                                                    Foreground="White">
                                                    編輯清單
                                                </Button>
                                                <Button
                                                    Width="120"
                                                    Padding="12,8"
                                                    HorizontalContentAlignment="Left"
                                                    Background="Transparent"
                                                    BorderBrush="{x:Null}"
                                                    Command="{Binding DataContext.DeleteFavoriteCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                    CommandParameter="{Binding}"
                                                    Cursor="Hand"
                                                    Foreground="#FF6B6B">
                                                    刪除清單
                                                </Button>
                                            </StackPanel>
                                        </Border>
                                    </Popup>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Grid>
</Page>
