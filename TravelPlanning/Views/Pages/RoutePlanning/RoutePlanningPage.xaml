<Page
    x:Class="TravelPlanning.Views.Pages.RoutePlanning.RoutePlanningPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:autoComplete="clr-namespace:TravelPlanning.Components.AutoCompleteComponent"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:TravelPlanning.Views.Pages.RoutePlanning"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="RoutePlanningPage"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Page.Resources>
        <SolidColorBrush x:Key="TextPrimary" Color="#E8EAED" />
    </Page.Resources>



    <Grid x:Name="container">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="4*" />
        </Grid.ColumnDefinitions>

        <Label
            Grid.Row="0"
            Grid.Column="0"
            Margin="0,20,0,0"
            HorizontalContentAlignment="Center"
            VerticalContentAlignment="Center">
            起點
        </Label>
        <autoComplete:AutoComplete
            Grid.Row="0"
            Grid.Column="1"
            Margin="0,20,0,0"
            VerticalContentAlignment="Center"
            SelectedCommand="{Binding AutoCompleteCommaned}"
            SelectedItem="{Binding Start}" />


        <Label
            Grid.Row="1"
            Grid.Column="0"
            Margin="0,20,0,0"
            HorizontalContentAlignment="Center"
            VerticalContentAlignment="Center">
            終點
        </Label>
        <autoComplete:AutoComplete
            Grid.Row="1"
            Grid.Column="1"
            Margin="0,20,0,0"
            VerticalContentAlignment="Center"
            SelectedCommand="{Binding AutoCompleteCommaned}"
            SelectedItem="{Binding End}" />


        <Button
            Grid.Row="2"
            Grid.Column="1"
            Width="100"
            Height="50"
            Margin="20"
            Command="{Binding RoutePlanningCommaned}">
            建立路線
        </Button>

    </Grid>
</Page>
