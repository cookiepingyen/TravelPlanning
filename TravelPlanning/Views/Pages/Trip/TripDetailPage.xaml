<Page
    x:Class="TravelPlanning.Views.Pages.Trip.TripDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:autoComplete="clr-namespace:TravelPlanning.Components.AutoCompleteComponent"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:TravelPlanning.Views.Pages.Trip"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="TripDetailPage"
    d:DesignHeight="800"
    d:DesignWidth="1000"
    mc:Ignorable="d">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <!--  ===== 色彩系統 =====  -->
        <SolidColorBrush x:Key="DarkBg" Color="#121212" />
        <SolidColorBrush x:Key="SurfaceBg" Color="#1E1E1E" />
        <SolidColorBrush x:Key="CardBg" Color="#2A2A2A" />
        <SolidColorBrush x:Key="DividerColor" Color="#3A3A3A" />
        <SolidColorBrush x:Key="AccentBlue" Color="#1E78E9" />
        <SolidColorBrush x:Key="AccentBlueLight" Color="#4DB8FF" />
        <SolidColorBrush x:Key="TextPrimary" Color="#F0F0F0" />
        <SolidColorBrush x:Key="TextSecondary" Color="#9E9E9E" />
        <SolidColorBrush x:Key="TextMuted" Color="#616161" />
        <SolidColorBrush x:Key="TabActiveBg" Color="#1A2433" />

        <!--  ===== 行程卡片樣式 =====  -->
        <Style x:Key="StopCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBg}" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <!--  ===== 可點擊卡片按鈕（無外觀，僅提供點擊）=====  -->
        <Style x:Key="PlaceCardButtonStyle" TargetType="Button">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  ===== 底部操作按鈕 =====  -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource CardBg}" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0,14" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#333333" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  ===== Tab 按鈕樣式 =====  -->
        <Style x:Key="TabButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="4,4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border
                            x:Name="TabBorder"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8">
                            <!--  ContentPresenter 直接渲染呼叫端傳入的 Content（Grid）  -->
                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource TabActiveBg}" />
                                <Setter Property="Foreground" Value="{StaticResource AccentBlue}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#252525" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid x:Name="RootGrid" Background="{StaticResource DarkBg}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition
                Width="340"
                MinWidth="300"
                MaxWidth="400" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  ==================== 左側面板 ====================  -->
        <Border
            Grid.Column="0"
            Height="800"
            Background="{StaticResource SurfaceBg}"
            BorderBrush="{StaticResource DividerColor}"
            BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <!--  Header  -->
                    <RowDefinition Height="Auto" />
                    <!--  Tabs  -->
                    <RowDefinition Height="Auto" />
                    <!--  加入地點按鈕  -->
                    <RowDefinition Height="Auto" />
                    <!--  Day info  -->
                    <RowDefinition Height="*" />
                    <!--  Scroll content  -->
                    <RowDefinition Height="Auto" />
                    <!--  Bottom buttons  -->
                </Grid.RowDefinitions>

                <!--  === Header：行程標題 + 編輯 ===  -->
                <Grid Grid.Row="0" Margin="20,20,20,12">
                    <TextBlock
                        FontSize="20"
                        FontWeight="Bold"
                        Foreground="{StaticResource TextPrimary}"
                        Text="行程" />
                    <Button
                        HorizontalAlignment="Right"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Foreground="{StaticResource TextSecondary}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontSize="16" Text="✎ " />
                            <TextBlock FontSize="13" Text="編輯" />
                        </StackPanel>
                    </Button>
                </Grid>

                <!--  === 日期導航列 ===  -->
                <Border
                    Grid.Row="1"
                    Margin="12,0,12,12"
                    Padding="4,4"
                    Background="{StaticResource CardBg}"
                    CornerRadius="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="32" />
                            <ColumnDefinition Width="36" />
                        </Grid.ColumnDefinitions>

                        <!--  左箭頭  -->
                        <Button
                            x:Name="BtnScrollLeft"
                            Grid.Column="0"
                            Width="28"
                            Height="28"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            BorderThickness="0"
                            Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border
                                        x:Name="Bg"
                                        Background="Transparent"
                                        CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bg" Property="Background" Value="#383838" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <TextBlock
                                FontSize="14"
                                Foreground="{StaticResource AccentBlue}"
                                Text="&#x276E;" />
                        </Button>



                        <!--  可捲動日期區  -->
                        <ScrollViewer
                            x:Name="DayTabScroller"
                            Grid.Column="1"
                            HorizontalScrollBarVisibility="Hidden"
                            VerticalScrollBarVisibility="Disabled">
                            <StackPanel x:Name="DayTabPanel" Orientation="Horizontal">

                                <ItemsControl ItemsSource="{Binding tripDaysContexts}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <RadioButton
                                                Command="{Binding DataContext.SelectDayCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding}"
                                                GroupName="DayTab"
                                                IsChecked="{Binding IsChecked}"
                                                Style="{StaticResource TabButtonStyle}">
                                                <RadioButton.Content>
                                                    <Grid Width="68">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="16" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <Button
                                                            Grid.Row="0"
                                                            Grid.RowSpan="3"
                                                            Grid.Column="1"
                                                            Padding="0"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Center"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Command="{Binding DataContext.DeleteDayBtnCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                            CommandParameter="{Binding}"
                                                            Cursor="Hand">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <ContentPresenter />
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                            <TextBlock
                                                                FontSize="11"
                                                                Foreground="#E05555"
                                                                Text="🗑" />
                                                        </Button>
                                                        <TextBlock
                                                            Grid.Row="0"
                                                            Grid.RowSpan="1"
                                                            Grid.Column="0"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            FontSize="12"
                                                            FontWeight="SemiBold"
                                                            Text="{Binding DateText}" />
                                                        <TextBlock
                                                            Grid.Row="2"
                                                            Grid.Column="0"
                                                            HorizontalAlignment="Center"
                                                            FontSize="10"
                                                            Opacity="0.7"
                                                            Text="{Binding Day, StringFormat=第{0}天}" />
                                                    </Grid>
                                                </RadioButton.Content>
                                            </RadioButton>


                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>


                            </StackPanel>
                        </ScrollViewer>

                        <!--  右箭頭  -->
                        <Button
                            x:Name="BtnScrollRight"
                            Grid.Column="2"
                            Width="28"
                            Height="28"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            BorderThickness="0"
                            Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border
                                        x:Name="Bg"
                                        Background="Transparent"
                                        CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bg" Property="Background" Value="#383838" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <TextBlock
                                FontSize="14"
                                Foreground="{StaticResource AccentBlue}"
                                Text="&#x276F;" />
                        </Button>

                        <!--  + 新增天數  -->
                        <Button
                            x:Name="BtnAddDay"
                            Grid.Column="3"
                            Width="30"
                            Height="30"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            BorderThickness="0"
                            Command="{Binding DataContext.AddDayBtnCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                            CommandParameter="{Binding TripID}"
                            Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border
                                        x:Name="Bg"
                                        Background="Transparent"
                                        CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bg" Property="Background" Value="#383838" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <TextBlock
                                FontSize="20"
                                FontWeight="Light"
                                Foreground="{StaticResource AccentBlue}"
                                Text="+" />
                        </Button>

                    </Grid>
                </Border>

                <!--  === 加入地點按鈕 ===  -->
                <Button
                    x:Name="BtnAddPlace"
                    Grid.Row="2"
                    Margin="20,0,20,12"
                    Padding="0,10"
                    HorizontalAlignment="Stretch"
                    Background="{StaticResource CardBg}"
                    BorderThickness="0"
                    Command="{Binding OpenAddPlaceCommand}"
                    Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border
                                x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#333333" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock
                            FontSize="16"
                            Foreground="{StaticResource AccentBlue}"
                            Text="＋ " />
                        <TextBlock
                            FontSize="13"
                            Foreground="{StaticResource TextPrimary}"
                            Text="加入地點" />
                    </StackPanel>
                </Button>

                <!--  === 加入地點 Popup ===  -->
                <Popup
                    x:Name="AddPlacePopup"
                    AllowsTransparency="True"
                    IsOpen="{Binding IsAddPlacePopupOpen, Mode=TwoWay}"
                    Placement="Center"
                    PlacementTarget="{Binding ElementName=RootGrid}"
                    PopupAnimation="Fade"
                    StaysOpen="False">
                    <Border
                        Width="300"
                        Padding="16"
                        Background="{StaticResource CardBg}"
                        BorderBrush="{StaticResource DividerColor}"
                        BorderThickness="1"
                        CornerRadius="10">
                        <StackPanel>
                            <TextBlock
                                Margin="0,0,0,10"
                                FontSize="14"
                                FontWeight="Bold"
                                Foreground="{StaticResource TextPrimary}"
                                Text="加入地點" />
                            <autoComplete:AutoComplete
                                Foreground="{StaticResource TextPrimary}"
                                SelectedCommand="{Binding SelectAddPlaceCommand}"
                                SelectedItem="{Binding PendingPlace}" />

                            <TextBlock
                                Margin="0,10,0,4"
                                FontSize="12"
                                Foreground="{StaticResource TextSecondary}"
                                Text="停留時間（分鐘）" />
                            <Border
                                Padding="10,8"
                                Background="#303030"
                                BorderBrush="{StaticResource DividerColor}"
                                BorderThickness="1"
                                CornerRadius="8">
                                <Grid>
                                    <TextBox
                                        x:Name="StayTimeTextBox"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        CaretBrush="{StaticResource TextPrimary}"
                                        Foreground="{StaticResource TextPrimary}"
                                        Text="{Binding PendingTimeText, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock
                                        Foreground="{StaticResource TextSecondary}"
                                        IsHitTestVisible="False"
                                        Text="分鐘，例如 30">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text, ElementName=StayTimeTextBox}" Value="">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Border>

                            <TextBlock
                                Margin="0,10,0,4"
                                FontSize="12"
                                Foreground="{StaticResource TextSecondary}"
                                Text="交通時間（分鐘）" />
                            <Border
                                Padding="10,8"
                                Background="#303030"
                                BorderBrush="{StaticResource DividerColor}"
                                BorderThickness="1"
                                CornerRadius="8">
                                <Grid>
                                    <TextBox
                                        x:Name="TransitTimeTextBox"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        CaretBrush="{StaticResource TextPrimary}"
                                        Foreground="{StaticResource TextPrimary}"
                                        Text="{Binding PendingTransitTimeText, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock
                                        Foreground="{StaticResource TextSecondary}"
                                        IsHitTestVisible="False"
                                        Text="分鐘，例如 15">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text, ElementName=TransitTimeTextBox}" Value="">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Border>

                            <CheckBox
                                x:Name="IsCustomCheckBox"
                                Margin="0,12,0,0"
                                Content="自訂時間"
                                Foreground="{StaticResource TextPrimary}"
                                IsChecked="{Binding IsCustom}" />

                            <TextBlock
                                Margin="0,10,0,4"
                                FontSize="12"
                                Foreground="{StaticResource TextSecondary}"
                                Text="到達時間" />
                            <StackPanel Orientation="Horizontal">
                                <Border
                                    Width="70"
                                    Padding="10,8"
                                    Background="#303030"
                                    BorderBrush="{StaticResource DividerColor}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    IsEnabled="{Binding IsChecked, ElementName=IsCustomCheckBox}">
                                    <TextBox
                                        Background="Transparent"
                                        BorderThickness="0"
                                        CaretBrush="{StaticResource TextPrimary}"
                                        Foreground="{StaticResource TextPrimary}"
                                        MaxLength="2"
                                        Text="{Binding PendingCustomHourText, UpdateSourceTrigger=PropertyChanged}" />
                                </Border>
                                <TextBlock
                                    Margin="6,0"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource TextSecondary}"
                                    Text="時" />
                                <Border
                                    Width="70"
                                    Padding="10,8"
                                    Background="#303030"
                                    BorderBrush="{StaticResource DividerColor}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    IsEnabled="{Binding IsChecked, ElementName=IsCustomCheckBox}">
                                    <TextBox
                                        Background="Transparent"
                                        BorderThickness="0"
                                        CaretBrush="{StaticResource TextPrimary}"
                                        Foreground="{StaticResource TextPrimary}"
                                        MaxLength="2"
                                        Text="{Binding PendingCustomMinuteText, UpdateSourceTrigger=PropertyChanged}" />
                                </Border>
                                <TextBlock
                                    Margin="6,0"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource TextSecondary}"
                                    Text="分" />
                            </StackPanel>

                            <StackPanel
                                Margin="0,14,0,0"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                                <Button
                                    Margin="0,0,8,0"
                                    Padding="14,6"
                                    Background="#333333"
                                    BorderThickness="0"
                                    Command="{Binding CancelAddPlaceCommand}"
                                    Cursor="Hand"
                                    Foreground="{StaticResource TextSecondary}">
                                    取消
                                </Button>
                                <Button
                                    Padding="14,6"
                                    Background="{StaticResource AccentBlue}"
                                    BorderThickness="0"
                                    Command="{Binding ConfirmAddPlaceCommand}"
                                    Cursor="Hand"
                                    Foreground="White">
                                    加入
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Popup>

                <!--  === 當天資訊列 ===  -->
                <Grid Grid.Row="3" Margin="20,0,20,12">
                    <StackPanel>
                        <TextBlock
                            FontSize="15"
                            FontWeight="Bold"
                            Foreground="{StaticResource AccentBlue}"
                            Text="{Binding CurrentDay.Day, StringFormat=第{0}天}" />
                        <TextBlock
                            FontSize="12"
                            Foreground="{StaticResource TextMuted}"
                            Text="{Binding CurrentDay.DateText}" />
                    </StackPanel>
                    <TextBlock
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="{StaticResource TextMuted}">
                        <Run Text="出發時間：" />
                        <Run
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextSecondary}"
                            Text="{Binding CurrentDay.StartTimeText, Mode=OneWay}" />
                    </TextBlock>
                </Grid>

                <!--  === 行程清單（可捲動）===  -->
                <ScrollViewer
                    Grid.Row="4"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12,0,12,0">

                        <ItemsControl ItemsSource="{Binding CurrentDay.TripDayPlaces}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Vertical">
                                        <!--  ── 景點 1：西門町 ──  -->
                                        <Grid Margin="0,0,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="44" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <!--  時間軸左欄  -->
                                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                                <TextBlock
                                                    HorizontalAlignment="Center"
                                                    FontSize="11"
                                                    Foreground="{StaticResource TextMuted}"
                                                    Text="{Binding StartTimeText}" />
                                                <TextBlock
                                                    HorizontalAlignment="Center"
                                                    FontSize="10"
                                                    Foreground="{StaticResource AccentBlue}"
                                                    Text="(自訂)"
                                                    Visibility="{Binding Is_custom, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                <!--  圓點  -->
                                                <Ellipse
                                                    Width="16"
                                                    Height="16"
                                                    HorizontalAlignment="Center"
                                                    Fill="{StaticResource AccentBlue}" />
                                                <!--  豎線  -->
                                                <Rectangle
                                                    Width="2"
                                                    Height="80"
                                                    HorizontalAlignment="Center"
                                                    Fill="{StaticResource DividerColor}" />
                                            </StackPanel>

                                            <!--  卡片內容  -->
                                            <Button
                                                x:Name="PlaceCardButton"
                                                Grid.Column="1"
                                                Margin="8,0,0,0"
                                                Command="{Binding DataContext.TogglePlaceMenuCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource PlaceCardButtonStyle}">
                                                <Border Style="{StaticResource StopCardStyle}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock
                                                                FontSize="15"
                                                                FontWeight="SemiBold"
                                                                Foreground="{StaticResource TextPrimary}"
                                                                Text="{Binding Place_name}" />
                                                            <TextBlock
                                                                FontSize="12"
                                                                Foreground="{StaticResource AccentBlue}"
                                                                Text="{Binding Stay_time, StringFormat=停留{0}分鐘}" />
                                                        </StackPanel>
                                                        <!--  縮圖  -->
                                                        <Border
                                                            Grid.Column="1"
                                                            Width="60"
                                                            Height="60"
                                                            Margin="8,0,0,0"
                                                            CornerRadius="8">
                                                            <Border.Background>
                                                                <ImageBrush ImageSource="https://upload.wikimedia.org/wikipedia/commons/thumb/3/3e/Ximending_20060111.jpg/320px-Ximending_20060111.jpg" Stretch="UniformToFill" />
                                                            </Border.Background>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </Button>

                                            <Popup
                                                AllowsTransparency="True"
                                                IsOpen="{Binding IsMenuOpen}"
                                                Placement="Right"
                                                PlacementTarget="{Binding ElementName=PlaceCardButton}"
                                                PopupAnimation="Fade"
                                                StaysOpen="False">
                                                <Border
                                                    Margin="4,0,0,0"
                                                    Padding="4"
                                                    Background="{StaticResource CardBg}"
                                                    BorderBrush="{StaticResource DividerColor}"
                                                    BorderThickness="1"
                                                    CornerRadius="8">
                                                    <Button
                                                        Padding="10,6"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Command="{Binding DataContext.DeletePlaceCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                        CommandParameter="{Binding}"
                                                        Cursor="Hand">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock
                                                                Margin="0,0,6,0"
                                                                FontSize="14"
                                                                Foreground="#E05555"
                                                                Text="🗑" />
                                                            <TextBlock Foreground="#E05555" Text="刪除" />
                                                        </StackPanel>
                                                    </Button>
                                                </Border>
                                            </Popup>
                                        </Grid>

                                        <!--  ── 交通段：約 1 分 ──  -->
                                        <Grid Margin="0,0,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="44" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                                <Rectangle
                                                    Width="2"
                                                    Height="20"
                                                    HorizontalAlignment="Center"
                                                    Fill="{StaticResource DividerColor}" />
                                                <Ellipse
                                                    Width="12"
                                                    Height="12"
                                                    HorizontalAlignment="Center"
                                                    Fill="Transparent"
                                                    Stroke="{StaticResource DividerColor}"
