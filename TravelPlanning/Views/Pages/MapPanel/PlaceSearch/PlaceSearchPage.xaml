<Page
    x:Class="TravelPlanning.Views.Pages.MapPanel.PlaceSearch.PlaceSearchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:autoComplete="clr-namespace:TravelPlanning.Components.AutoCompleteComponent"
    xmlns:converters="clr-namespace:TravelPlanning.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:TravelPlanning.Views.Pages.MapPanel.PlaceSearch"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="PlaceSearchPage"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <Page.Resources>
        <!--  深色背景色  -->
        <SolidColorBrush x:Key="DarkBg" Color="#1E1E1E" />
        <SolidColorBrush x:Key="DarkNavBg" Color="#2A2A2A" />
        <SolidColorBrush x:Key="DarkSidebarBg" Color="#242424" />
        <SolidColorBrush x:Key="DarkBorder" Color="#3A3A3A" />
        <SolidColorBrush x:Key="ActiveBlue" Color="#4DA3FF" />
        <SolidColorBrush x:Key="ActiveBlueBg" Color="#1A3A5C" />
        <SolidColorBrush x:Key="TextPrimary" Color="#E8EAED" />
        <SolidColorBrush x:Key="TextSecondary" Color="#9AA0A6" />
        <SolidColorBrush x:Key="InputBg" Color="#303030" />
        <SolidColorBrush x:Key="ToggleBg" Color="#2A2A2A" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:RatingToStarsConverter x:Key="RatingToStarsConverter" />
        <Style x:Key="TabRadioButtonStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0,0,0,2" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource ActiveBlue}" />
                                <Setter Property="BorderBrush" Value="{StaticResource ActiveBlue}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
                                <Setter Property="BorderBrush" Value="Transparent" />
                                <Setter Property="FontWeight" Value="Normal" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <StackPanel Margin="16">
            <TextBlock
                Margin="0,0,0,12"
                FontSize="16"
                FontWeight="Bold"
                Foreground="{StaticResource TextPrimary}"
                Text="地點搜尋" />

            <!--  搜尋框  -->
            <autoComplete:AutoComplete SelectedCommand="{Binding AutoCompleteCommaned}" />

            <!--  ===== PlaceCard 詳細資訊面板 =====  -->
            <Border
                x:Name="PlaceCardPanel"
                Margin="0,8,0,0"
                Padding="16"
                Background="#2C2C2C"
                BorderBrush="{StaticResource DarkBorder}"
                BorderThickness="1"
                CornerRadius="12"
                Visibility="{Binding IsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>

                    <!--  地點圖片  -->
                    <Border
                        Margin="-16,-16,-16,12"
                        ClipToBounds="True"
                        CornerRadius="12,12,0,0">
                        <Image
                            Height="200"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Source="{Binding Photo}"
                            Stretch="UniformToFill" />
                    </Border>

                    <!--  地點名稱  -->
                    <TextBlock
                        Margin="0,0,0,6"
                        FontSize="16"
                        FontWeight="Bold"
                        Foreground="{StaticResource TextPrimary}"
                        Text="{Binding PlaceName}"
                        TextWrapping="Wrap" />

                    <!--  評分 + 評論數  -->
                    <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="#FBBC04"
                            Text="{Binding Rating}" />
                        <TextBlock
                            Margin="2,0,4,0"
                            VerticalAlignment="Center"
                            FontSize="13"
                            Foreground="#FBBC04"
                            Text="{Binding Rating, Converter={StaticResource RatingToStarsConverter}}" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="12"
                            Foreground="{StaticResource TextSecondary}"
                            Text="{Binding UserRatingsTotal}" />
                    </StackPanel>

                    <Separator Margin="0,0,0,8" Background="{StaticResource DarkBorder}" />

                    <!--  Tab 列：總覽 / 評論  -->
                    <StackPanel Margin="0,0,0,4" Orientation="Horizontal">
                        <RadioButton
                            Padding="16,6"
                            Background="Transparent"
                            Command="{Binding OverviewClickCommand}"
                            Content="總覽"
                            Cursor="Hand"
                            FontSize="13"
                            FontWeight="SemiBold"
                            GroupName="TabGroup"
                            IsChecked="True"
                            Style="{StaticResource TabRadioButtonStyle}" />
                        <RadioButton
                            Padding="16,6"
                            Background="Transparent"
                            Command="{Binding CommentClickCommand}"
                            Content="評論"
                            Cursor="Hand"
                            FontSize="13"
                            GroupName="TabGroup"
                            Style="{StaticResource TabRadioButtonStyle}" />
                    </StackPanel>

                    <Separator Margin="0,0,0,12" Background="{StaticResource DarkBorder}" />

                    <Frame
                        x:Name="frame"
                        Grid.Row="1"
                        NavigationUIVisibility="Hidden" />

                </StackPanel>

            </Border>
            <!--  ===== PlaceCard 結束 =====  -->

        </StackPanel>
    </Grid>
</Page>
