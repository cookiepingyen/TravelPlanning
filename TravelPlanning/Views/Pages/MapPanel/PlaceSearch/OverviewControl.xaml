<UserControl
    x:Class="TravelPlanning.Views.Pages.MapPanel.PlaceSearch.OverviewControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:TravelPlanning.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:TravelPlanning.Views.Pages.MapPanel.PlaceSearch"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <UserControl.Resources>
        <!--  深色背景色  -->
        <SolidColorBrush x:Key="DarkBg" Color="#1E1E1E" />
        <SolidColorBrush x:Key="DarkNavBg" Color="#2A2A2A" />
        <SolidColorBrush x:Key="DarkSidebarBg" Color="#242424" />
        <SolidColorBrush x:Key="DarkBorder" Color="#3A3A3A" />
        <SolidColorBrush x:Key="ActiveBlue" Color="#4DA3FF" />
        <SolidColorBrush x:Key="ActiveBlueBg" Color="#1A3A5C" />
        <SolidColorBrush x:Key="TextPrimary" Color="#E8EAED" />
        <SolidColorBrush x:Key="TextSecondary" Color="#9AA0A6" />
        <SolidColorBrush x:Key="InputBg" Color="#303030" />
        <SolidColorBrush x:Key="ToggleBg" Color="#2A2A2A" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:RatingToStarsConverter x:Key="RatingToStarsConverter" />
    </UserControl.Resources>

    <Grid Cursor="">
        <Grid.RowDefinitions>
            <RowDefinition Height="23*"/>
            <RowDefinition Height="67*"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Vertical" Grid.RowSpan="2">
            <!--  動作按鈕列：規劃路線 / 儲存地點  -->
            <StackPanel
                Margin="0,0,0,12"
                HorizontalAlignment="Left"
                Orientation="Horizontal">

                <!--  規劃路線  -->
                <StackPanel
                    Width="60"
                    Margin="0,0,16,0"
                    HorizontalAlignment="Center"
                    Cursor="Hand">
                    <Border
                        Width="44"
                        Height="44"
                        HorizontalAlignment="Center"
                        Background="{StaticResource ActiveBlueBg}"
                        CornerRadius="22">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="MouseLeftButtonUp">
                                <i:InvokeCommandAction Command="{Binding RoutePlanningPageCommand}" />
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                        <ui:SymbolIcon
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource ActiveBlue}"
                            Symbol="Navigation24" />
                    </Border>
                    <TextBlock
                        Margin="0,4,0,0"
                        HorizontalAlignment="Center"
                        FontSize="11"
                        Foreground="{StaticResource TextSecondary}"
                        Text="規劃路線"
                        TextAlignment="Center"
                        TextWrapping="Wrap" />
                </StackPanel>

                <!--  儲存地點  -->
                <StackPanel
                    Width="60"
                    HorizontalAlignment="Center"
                    Cursor="Hand">
                    <Grid HorizontalAlignment="Center">
                        <ToggleButton
                            x:Name="SaveToggleButton"
                            Width="44"
                            Height="44"
                            Cursor="Hand">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <ContentPresenter />
                                </ControlTemplate>
                            </ToggleButton.Template>
                            <Border
                                Width="44"
                                Height="44"
                                Background="{StaticResource InputBg}"
                                CornerRadius="22">
                                <ui:SymbolIcon
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource TextPrimary}"
                                    Symbol="Bookmark24" />
                            </Border>
                        </ToggleButton>

                        <Popup
                            AllowsTransparency="True"
                            IsOpen="{Binding IsChecked, ElementName=SaveToggleButton, Mode=TwoWay}"
                            Placement="Bottom"
                            PlacementTarget="{Binding ElementName=SaveToggleButton}"
                            StaysOpen="False">
                            <Border
                                Background="#2D2D2D"
                                BorderBrush="#444444"
                                BorderThickness="1"
                                CornerRadius="8">
                                <StackPanel MinWidth="160">
                                    <TextBlock
                                        Margin="12,8,12,4"
                                        FontSize="12"
                                        Foreground="{StaticResource TextSecondary}"
                                        Text="加入清單" />
                                    <ItemsControl ItemsSource="{Binding FavoriteListItems}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button
                                                    Width="160"
                                                    Padding="12,8"
                                                    HorizontalContentAlignment="Left"
                                                    Background="Transparent"
                                                    BorderBrush="{x:Null}"
                                                    Command="{Binding DataContext.AddToFavoriteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Cursor="Hand"
                                                    Foreground="White">
                                                    <StackPanel Orientation="Horizontal">
                                                        <ui:SymbolIcon
                                                            Margin="0,0,8,0"
                                                            VerticalAlignment="Center"
                                                            Foreground="#8AB4F8"
                                                            Symbol="{Binding Icon}" />
                                                        <TextBlock VerticalAlignment="Center" Text="{Binding Name}" />
                                                    </StackPanel>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                    <TextBlock
                        Margin="0,4,0,0"
                        HorizontalAlignment="Center"
                        FontSize="11"
                        Foreground="{StaticResource TextSecondary}"
                        Text="儲存地點"
                        TextAlignment="Center"
                        TextWrapping="Wrap" />
                </StackPanel>

            </StackPanel>

            <Separator Margin="0,0,0,8" Background="{StaticResource DarkBorder}" />


            <!--  營業狀態  -->
            <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
                <ui:SymbolIcon
                    Margin="0,0,8,0"
                    Foreground="#34A853"
                    Symbol="Clock24" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="13"
                    Foreground="#34A853"
                    Text="{Binding placeOverview.BusinessStatus}" />
            </StackPanel>

            <!--  地址  -->
            <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
                <ui:SymbolIcon
                    Margin="0,0,8,0"
                    Foreground="{StaticResource TextSecondary}"
                    Symbol="Location24" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="12"
                    Foreground="{StaticResource TextSecondary}"
                    Text="{Binding placeOverview.Address}"
                    TextWrapping="Wrap" />
            </StackPanel>

            <!--  電話  -->
            <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon
                    Margin="0,0,8,0"
                    Foreground="{StaticResource TextSecondary}"
                    Symbol="Call24" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="12"
                    Foreground="{StaticResource TextSecondary}"
                    Text="{Binding placeOverview.Phone}" />
            </StackPanel>

        </StackPanel>
    </Grid>
</UserControl>
