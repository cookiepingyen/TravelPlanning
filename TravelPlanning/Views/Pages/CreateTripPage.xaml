<Page
    x:Class="TravelPlanning.Views.Pages.CreateTripPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:TravelPlanning.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="CreateTripPage"
    d:DesignHeight="600"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <Page.Resources>

        <!--  標題文字（含紅色星號）共用樣式  -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#E0E0E0" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <!--  輸入框樣式  -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2A2A2A" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#3A3A3A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,0,0,0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Height" Value="44" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="CaretBrush" Value="White" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                            <ScrollViewer
                                x:Name="PART_ContentHost"
                                Margin="{TemplateBinding Padding}"
                                VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  取消按鈕  -->
        <Style x:Key="CancelButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#9A9AA0" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Padding" Value="20,10" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  下一步 / 送出按鈕（藍色）  -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#1A73E8" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Padding" Value="32,12" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E0405E" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Background="#2A2A2A">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  主內容（填滿）  -->
        <StackPanel Grid.Row="0" Margin="32,24,32,16">

            <TextBlock
                Margin="0,0,0,20"
                FontSize="22"
                FontWeight="Bold"
                Foreground="White"
                Text="建立行程" />

            <!--  封面圖（放在最上方，填滿寬度）  -->
            <StackPanel Margin="0,0,0,20">
                <TextBlock Style="{StaticResource FieldLabel}">
                    <Run Foreground="#F0506E" Text="*" />
                    <Run Text=" 封面圖" />
                </TextBlock>

                <Border
                    Height="280"
                    Background="#2A2A2A"
                    BorderBrush="#3A3A3A"
                    BorderThickness="1"
                    CornerRadius="8"
                    Cursor="Hand">
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="MouseLeftButtonUp">
                            <i:InvokeCommandAction Command="{Binding UploadImageCommand}" />
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                    <Grid>
                        <Image Source="{Binding CoverImg}" Stretch="Uniform">
                            <Image.Style>
                                <Style TargetType="Image">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CoverImg}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Image.Style>
                        </Image>
                    </Grid>
                </Border>
            </StackPanel>

            <!--  行程名稱  -->
            <StackPanel Margin="0,0,0,20">
                <TextBlock Style="{StaticResource FieldLabel}">
                    <Run Foreground="#F0506E" Text="*" />
                    <Run Text=" 行程名稱" />
                </TextBlock>
                <TextBox Tag="請輸入行程名稱" Text="{Binding Name}" />
            </StackPanel>

            <!--  開始日期 / 天數 並排  -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Style="{StaticResource FieldLabel}">
                        <Run Foreground="#F0506E" Text="*" />
                        <Run Text=" 開始日期" />
                    </TextBlock>
                    <DatePicker SelectedDate="{Binding Date}" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Style="{StaticResource FieldLabel}">
                        <Run Foreground="#F0506E" Text="*" />
                        <Run Text=" 天數" />
                    </TextBlock>
                    <TextBox Text="{Binding Days}" />
                </StackPanel>
            </Grid>

        </StackPanel>

        <!--  分隔線 + 取消 / 送出 按鈕（固定在底部）  -->
        <StackPanel Grid.Row="1" Margin="32,0,32,20">
            <Border
                Margin="0,0,0,16"
                BorderBrush="#3A3A42"
                BorderThickness="0,1,0,0" />

            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button
                    Command="{Binding CancelCommand}"
                    Content="取消"
                    Style="{StaticResource CancelButton}" />
                <Button
                    Margin="12,0,0,0"
                    Command="{Binding CreateTripCommand}"
                    Content="送出"
                    Style="{StaticResource PrimaryButton}" />
            </StackPanel>
        </StackPanel>

    </Grid>
</Page>