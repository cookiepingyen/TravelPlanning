<UserControl
    x:Class="TravelPlanning.Components.CommentComponent.Comment"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:TravelPlanning.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:TravelPlanning.Components.CommentComponent"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <UserControl.Resources>
        <converters:RatingToStarsConverter x:Key="RatingToStarsConverter" />
    </UserControl.Resources>

    <Border
        Margin="0,0,0,8"
        Padding="16"
        Background="#2A2A2A"
        CornerRadius="8">
        <StackPanel>

            <!--  第一行：頭像 + 名稱/標籤  -->
            <StackPanel Margin="0,0,0,8" Orientation="Horizontal">

                <!--  頭像  -->
                <Grid Width="40" Height="40">
                    <Ellipse>
                        <Ellipse.Fill>
                            <ImageBrush ImageSource="{Binding profile_photo_url}" Stretch="UniformToFill" />
                        </Ellipse.Fill>
                    </Ellipse>
                </Grid>

                <!--  名稱 + 在地嚮導標籤  -->
                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                    <TextBlock
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="#E8EAED"
                        Text="{Binding author_name}" />
                </StackPanel>

            </StackPanel>

            <!--  第二行：星星 + 時間  -->
            <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="13"
                    Foreground="#FBBC04"
                    Text="{Binding rating, Converter={StaticResource RatingToStarsConverter}}" />
                <TextBlock
                    Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    FontSize="12"
                    Foreground="#9AA0A6"
                    Text="{Binding relative_time_description}" />
            </StackPanel>

            <!--  第三行：評論內容  -->
            <TextBlock
                FontSize="13"
                Foreground="#E8EAED"
                LineHeight="20"
                Text="{Binding text}"
                TextTrimming="CharacterEllipsis"
                TextWrapping="Wrap">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="MaxHeight" Value="40" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsChecked, ElementName=ExpandToggle}" Value="True">
                                <Setter Property="MaxHeight" Value="9999" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!--  展開/收合按鈕  -->
            <ToggleButton
                x:Name="ExpandToggle"
                Margin="0,4,0,0"
                Padding="0"
                HorizontalAlignment="Left"
                Background="Transparent"
                BorderThickness="0"
                Cursor="Hand"
                FontSize="12">
                <ToggleButton.Style>
                    <Style TargetType="ToggleButton">
                        <Setter Property="Foreground" Value="#9AA0A6" />
                        <Setter Property="Content" Value="更多" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ToggleButton">
                                    <TextBlock
                                        Foreground="{TemplateBinding Foreground}"
                                        FontSize="{TemplateBinding FontSize}"
                                        Text="{TemplateBinding Content}" />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Content" Value="收合" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ToggleButton.Style>
            </ToggleButton>

        </StackPanel>
    </Border>
</UserControl>